{
  "name": "@chatcoder/bot",
  "version": "0.6.1",
  "private": true,
  "type": "module",
  "main": "dist/main.js",
  "exports": {
    ".": "./dist/main.js",
    "./db": {
      "types": "./dist/db/index.d.ts",
      "import": "./dist/db/index.js"
    },
    "./db/apiKeys": {
      "types": "./dist/db/apiKeys.d.ts",
      "import": "./dist/db/apiKeys.js"
    },
    "./db/profiles": {
      "types": "./dist/db/profiles.d.ts",
      "import": "./dist/db/profiles.js"
    },
    "./db/sessions": {
      "types": "./dist/db/sessions.d.ts",
      "import": "./dist/db/sessions.js"
    },
    "./db/messages": {
      "types": "./dist/db/messages.d.ts",
      "import": "./dist/db/messages.js"
    },
    "./db/admin": {
      "types": "./dist/db/admin.d.ts",
      "import": "./dist/db/admin.js"
    },
    "./api/server": {
      "types": "./dist/api/server.d.ts",
      "import": "./dist/api/server.js"
    }
  },
  "scripts": {
    "build": "tsc -b",
    "dev": "node ../../scripts/dev-runner.mjs dist/main.js",
    "start": "node dist/main.js"
  },
  "dependencies": {
    "@chatcoder/shared": "0.1.0",
    "@fastify/cors": "^9.0.1",
    "better-sqlite3": "^11.0.0",
    "fastify": "^4.28.0",
    "grammy": "^1.24.1",
    "kysely": "^0.27.3",
    "pg": "^8.11.5",
    "pino": "^9.1.0",
    "pino-pretty": "^11.1.0",
    "zod": "^3.23.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.10",
    "@types/pg": "^8.11.5"
  }
}
